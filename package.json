{
  "name": "dronegohub",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm --filter @dronegohub/web dev",
    "build": "pnpm --filter @dronegohub/web build",
    "preview": "pnpm --filter @dronegohub/web preview",
    "typecheck": "pnpm --filter @dronegohub/web typecheck",
    "test": "pnpm --filter @dronegohub/web test",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0"
  }
}
